# ===== APP =====
APP_TITLE=DiabetAI API
ENV=dev
ROOT_PATH=

# ===== DATABASE =====
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/medoed

# ===== JWT =====
# Generate a strong random value, e.g. `openssl rand -hex 32`
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== EMAIL (SMTP over SSL) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=no-reply@example.com
SMTP_PASS=your_smtp_password
FROM_EMAIL=no-reply@example.com

# ===== GOOGLE SIGN-IN =====
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_SECRET=your_google_web_client_secret
# Comma-separated list of allowed audiences (client IDs) accepted from id_token
GOOGLE_ALLOWED_AUDS=your-ios-client-id.apps.googleusercontent.com,your-web-client-id.apps.googleusercontent.com

# ===== SIGN IN WITH APPLE =====
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_BUNDLE_ID=com.example.medoed
# Path to your AuthKey_XXXXXXXXXX.p8 private key (keep it out of version control)
APPLE_PRIVATE_KEY_PATH=./secrets/AuthKey.p8
